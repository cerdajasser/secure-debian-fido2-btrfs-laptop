# ============================================================
# Jazzer's Zsh — Oh-My-Zsh + Starship + fzf-tab
# Clean, fast, defensive, and fancy.
# ============================================================

# ---------- Helpers ----------
is_interactive() { [[ $- == *i* ]]; }
has() { command -v "$1" >/dev/null 2>&1; }

path_prepend() {
  [[ -d "$1" ]] || return
  case ":$PATH:" in
    *":$1:"*) ;;
    *) export PATH="$1${PATH:+:$PATH}" ;;
  esac
}

xdg_prepend() {
  [[ -d "$1" ]] || return
  case ":${XDG_DATA_DIRS:-}:" in
    *":$1:"*) ;;
    *) export XDG_DATA_DIRS="$1${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}" ;;
  esac
}

# Deduplicate zsh path/fpath arrays.
typeset -U path fpath

# ---------- Base environment ----------
export EDITOR="${EDITOR:-nano}"
export VISUAL="${VISUAL:-$EDITOR}"
export PAGER="${PAGER:-less}"

export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
mkdir -p "$XDG_CACHE_HOME/zsh" "$XDG_CACHE_HOME/zsh/completions" 2>/dev/null

# PATH priority: local user tools first.
export PYENV_ROOT="$HOME/.pyenv"

#path_prepend "$HOME/.local/share/gem/ruby/3.3.0/bin"
#path_prepend "$HOME/.cargo/bin"
#path_prepend "$PYENV_ROOT/bin"
#path_prepend "$HOME/bin"
#path_prepend "$HOME/.local/bin"
path_prepend "$HOME/.local/share/gem/ruby/3.3.0/bin"
path_prepend "$HOME/.atuin/bin"
path_prepend "$HOME/.cargo/bin"
path_prepend "$HOME/go/bin"
path_prepend "$PYENV_ROOT/bin"
path_prepend "$HOME/bin"
path_prepend "$HOME/.local/bin"

# Flatpak desktop/app exports.
xdg_prepend "/var/lib/flatpak/exports/share"
xdg_prepend "$HOME/.local/share/flatpak/exports/share"

# Debian sometimes exposes bat as batcat.
if ! has bat && has batcat; then
  alias bat='batcat'
fi

# Avoid plain C locale weirdness in interactive apps.
if [[ -z "${LANG:-}" || "$LANG" == "C" ]]; then
  if locale -a 2>/dev/null | grep -qi '^en_US\.utf8$'; then
    export LANG="en_US.UTF-8"
  else
    export LANG="C.UTF-8"
  fi
fi
export LC_CTYPE="${LC_CTYPE:-$LANG}"

# Stop here for non-interactive shells after env setup.
is_interactive || return 0

# ---------- Oh-My-Zsh ----------
export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="${ZSH_CUSTOM:-$ZSH/custom}"

ZSH_THEME=""                       # Starship handles prompt.
CASE_SENSITIVE="false"
HYPHEN_INSENSITIVE="true"
ENABLE_CORRECTION="false"          # Less annoying for security/dev commands.
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"

# External zsh-completions must be added before Oh-My-Zsh/compinit.
if [[ -d "$ZSH_CUSTOM/plugins/zsh-completions/src" ]]; then
  fpath=("$ZSH_CUSTOM/plugins/zsh-completions/src" $fpath)
fi

# ---------- Completion styling ----------
autoload -Uz colors && colors
zmodload zsh/complist 2>/dev/null

zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$XDG_CACHE_HOME/zsh/completions"
zstyle ':completion:*' menu select
zstyle ':completion:*' group-name ''
zstyle ':completion:*' verbose yes
zstyle ':completion:*' matcher-list \
  'm:{a-z}={A-Za-z}' \
  'r:|[._-]=** r:|=**'

zstyle ':completion:*:descriptions' format '%F{blue}-- %d --%f'
zstyle ':completion:*:messages' format '%F{yellow}%d%f'
zstyle ':completion:*:warnings' format '%F{red}No matches found%f'

if has dircolors; then
  eval "$(dircolors -b 2>/dev/null)"
fi
[[ -n "${LS_COLORS:-}" ]] && zstyle ':completion:*:default' list-colors ${(s.:.)LS_COLORS}

# ---------- fzf / fzf-tab ----------
export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:---height 40% --layout=reverse --border --info=inline}"

if has rg; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git/*"'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
fi

zstyle ':fzf-tab:*' switch-group '<' '>'
zstyle ':fzf-tab:*' show-group full
zstyle ':fzf-tab:*' fzf-flags --height=40% --layout=reverse --border

# Nice previews when completing paths.
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'lsd -la --color=always "$realpath" 2>/dev/null || ls -la "$realpath"'
zstyle ':fzf-tab:complete:ls:*' fzf-preview 'lsd -la --color=always "$realpath" 2>/dev/null || ls -la "$realpath"'
zstyle ':fzf-tab:complete:bat:*' fzf-preview 'bat --color=always --style=numbers --line-range=:200 "$realpath" 2>/dev/null'

# ---------- Plugin-specific config ----------
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=30
ZSH_AUTOSUGGEST_USE_ASYNC=true

ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern)
typeset -A ZSH_HIGHLIGHT_STYLES
ZSH_HIGHLIGHT_STYLES[unknown-token]='fg=red,bold'
ZSH_HIGHLIGHT_STYLES[reserved-word]='fg=magenta,bold'
ZSH_HIGHLIGHT_STYLES[alias]='fg=cyan'
ZSH_HIGHLIGHT_STYLES[builtin]='fg=green'
ZSH_HIGHLIGHT_STYLES[function]='fg=green'
ZSH_HIGHLIGHT_STYLES[command]='fg=green'

# Build plugin list safely. Missing plugins are skipped instead of causing noise.
plugins=()
_want_plugins=(
  git
  debian
  sudo
  colored-man-pages
  command-not-found
  extract
  history-substring-search
  docker
  docker-compose
  systemd
  python
  pip
  fzf
  zsh-completions
  zsh-autosuggestions
  fzf-tab
  zsh-syntax-highlighting
)

for _p in "${_want_plugins[@]}"; do
  if [[ -d "$ZSH/plugins/$_p" || -d "$ZSH_CUSTOM/plugins/$_p" ]]; then
    plugins+=("$_p")
  fi
done
unset _p _want_plugins

# Load Oh-My-Zsh. If it is missing, fall back to basic compinit.
if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
else
  autoload -Uz compinit
  compinit -i -d "$XDG_CACHE_HOME/zsh/zcompdump-${ZSH_VERSION}"
fi

# ---------- History ----------
HISTFILE="$HOME/.zsh_history"
HISTSIZE=200000
SAVEHIST=200000

setopt EXTENDED_HISTORY
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS
setopt HIST_REDUCE_BLANKS
setopt HIST_VERIFY
setopt HIST_IGNORE_SPACE

# ---------- Shell behavior ----------
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_SILENT
setopt PUSHD_IGNORE_DUPS
setopt INTERACTIVE_COMMENTS
setopt GLOB_DOTS
setopt NO_BEEP
unsetopt FLOW_CONTROL

KEYTIMEOUT=15
bindkey -e

# History substring search arrows.
if (( $+functions[history-substring-search-up] )); then
  bindkey '^[[A' history-substring-search-up
  bindkey '^[[B' history-substring-search-down
fi

# Word movement.
bindkey '^[[1;5C' forward-word
bindkey '^[[1;5D' backward-word
bindkey '^H' backward-kill-word

# ---------- Tool hooks ----------
if has pyenv; then
  eval "$(pyenv init - zsh)"
  _pyenv_venv_init="$(pyenv virtualenv-init - zsh 2>/dev/null)" && eval "$_pyenv_venv_init"
  unset _pyenv_venv_init
fi

has zoxide && eval "$(zoxide init zsh)"
has direnv && eval "$(direnv hook zsh)"

# Atuin shell history
if has atuin; then
  eval "$(atuin init zsh)"
fi

# Starship prompt last-ish so it owns the prompt cleanly.
has starship && eval "$(starship init zsh)"

# ---------- Aliases ----------
if has lsd; then
  alias ls='lsd --group-dirs first'
  alias l='lsd -l --group-dirs first'
  alias la='lsd -a --group-dirs first'
  alias lla='lsd -la --group-dirs first'
  alias lt='lsd --tree --group-dirs first'
elif has eza; then
  alias ls='eza --group-directories-first --icons=auto'
  alias l='eza -l --group-directories-first --icons=auto'
  alias la='eza -a --group-directories-first --icons=auto'
  alias lla='eza -la --group-directories-first --icons=auto'
  alias lt='eza --tree --group-directories-first --icons=auto'
else
  alias ls='ls --color=auto'
  alias l='ls -l'
  alias la='ls -a'
  alias lla='ls -la'
fi

alias grep='grep --color=auto'
alias df='df -h'
alias du='du -h'
alias free='free -h'
alias mkdir='mkdir -pv'
alias cls='clear'
alias reload='source ~/.zshrc'
alias zshrc='$EDITOR ~/.zshrc'
alias path='print -l $path'

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ---------- Image preview ----------
if has chafa; then
  imgcat() {
    if [[ $# -eq 0 ]]; then
      echo "usage: imgcat <image>"
      return 1
    fi
    chafa "$@"
  }
fi

# ---------- Terminal toys ----------
has cmatrix && alias matrix='cmatrix -ab'
has sl && alias train='sl'
has figlet && has lolcat && alias banner='figlet Jazzer | lolcat'
has toilet && has lolcat && alias cyberbanner='toilet -f pagga Jazzer | lolcat'

# ---------- GUI app launchers ----------
if command -v resources >/dev/null 2>&1; then
  alias resources='resources'
elif command -v flatpak >/dev/null 2>&1; then
  alias resources='flatpak run net.nokyan.Resources'
fi

if command -v sniffnet >/dev/null 2>&1; then
  alias sniffnet='sniffnet'
elif command -v flatpak >/dev/null 2>&1; then
  alias sniffnet='flatpak run org.sniffnet.Sniffnet'
fi

# ---------- Network / system monitor helpers ----------
has btop && alias top='btop'
has nvtop && alias gputop='nvtop'
has duf && alias disks='duf'
has dust && alias usage='dust'

has nethogs && alias netapps='sudo nethogs'
has iftop && alias nettop='sudo iftop'
has bmon && alias netgraph='bmon'
has nload && alias netload='nload'
has vnstat && alias netstatx='vnstat'

# ---------- Yazi terminal file manager ----------
if has yazi; then
  alias yy='yazi'
  alias files='yazi'

  # Open yazi and cd into the directory you exit from
  y() {
    local tmp cwd
    tmp="$(mktemp -t yazi-cwd.XXXXXX)"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat "$tmp" 2>/dev/null)" && [[ -n "$cwd" && "$cwd" != "$PWD" ]]; then
      cd -- "$cwd"
    fi
    rm -f "$tmp"
  }
fi

# ---------- Jazzer dashboard ----------
dash() {
  clear

  if has fastfetch && [[ -r "$HOME/.config/fastfetch/config-graphite.jsonc" ]]; then
    fastfetch -c "$HOME/.config/fastfetch/config-graphite.jsonc"
  elif has fastfetch; then
    fastfetch
  fi

  echo
  echo "Quick commands:"
  echo "  top        -> btop if installed"
  echo "  gputop     -> nvtop if installed"
  echo "  netapps    -> sudo nethogs"
  echo "  nettop     -> sudo iftop"
  echo "  netgraph   -> bmon"
  echo "  y          -> yazi with cd-on-exit"
  echo "  h <cmd>    -> tldr help"
  echo "  atuin search"
}

# ---------- TLDR / Tealdeer ----------
# Friendly examples for commands: `tldr tar`, `tldr docker`, etc.

if has tldr; then
  alias helpme='tldr'
  alias howto='tldr'
  alias examples='tldr'

  # Quick command help: h tar, h docker, h systemctl
  h() {
    if [[ $# -eq 0 ]]; then
      echo "usage: h <command>"
      echo "example: h tar"
      return 1
    fi

    tldr "$@"
  }

  # Try tldr first, fall back to man.
  hm() {
    if [[ $# -eq 0 ]]; then
      echo "usage: hm <command>"
      echo "example: hm rsync"
      return 1
    fi

    tldr "$@" 2>/dev/null || man "$@"
  }

  # Update local tldr pages.
  alias tldru='tldr --update'
fi
# Debian fd binary name compatibility.
if ! has fd && has fdfind; then
  alias fd='fdfind'
fi

# Docker / Compose convenience.
alias d='docker'
alias dc='docker compose'
alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dlog='docker logs -f'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'

# Git helpers beyond Oh-My-Zsh defaults.
alias gst='git status --short --branch'
alias glog='git log --oneline --decorate --graph --all -n 25'
alias gundo='git reset --soft HEAD~1'

# Networking / admin helpers.
alias ports='ss -tulpn'
alias myip='curl -4 ifconfig.me 2>/dev/null; echo'
alias update='sudo apt update && sudo apt full-upgrade'
alias cleanup='sudo apt autoremove --purge && sudo apt autoclean'

# ---------- Functions ----------
mkcd() {
  if [[ $# -ne 1 ]]; then
    print "usage: mkcd <directory>" >&2
    return 2
  fi
  mkdir -p -- "$1" && cd -- "$1"
}

serve() {
  local port="${1:-8000}"
  python3 -m http.server "$port"
}

pathclean() {
  path=("${(@u)path}")
  export PATH
  print -P "%F{green}PATH deduplicated.%f"
}

please() {
  sudo $(fc -ln -1)
}

# ---------- Man page / less colors ----------
export LESS='-R'
export LESS_TERMCAP_mb=$'\e[1;31m'
export LESS_TERMCAP_md=$'\e[1;36m'
export LESS_TERMCAP_me=$'\e[0m'
export LESS_TERMCAP_se=$'\e[0m'
export LESS_TERMCAP_so=$'\e[1;45;97m'
export LESS_TERMCAP_ue=$'\e[0m'
export LESS_TERMCAP_us=$'\e[1;32m'
if has bat; then
  export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

##loading libs

export XDG_DATA_DIRS="$HOME/.local/share/flatpak/exports/share:/var/lib/flatpak/exports/share:/usr/local/share:/usr/share"
export XDG_CONFIG_DIRS="/etc/xdg"

# ---------- Local private overrides ----------
# Put machine-specific secrets/exports in ~/.zshrc.local instead of this file.
[[ -r "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"

# ---------- Login banner ----------
#if [[ -t 1 && "$TERM" != dumb && -z "${NO_FASTFETCH:-}" ]]; then
#  if has fastfetch; then
#    if [[ -r "$HOME/.config/fastfetch/config-pokemon.jsonc" ]]; then
#      fastfetch -c "$HOME/.config/fastfetch/config-pokemon.jsonc"
