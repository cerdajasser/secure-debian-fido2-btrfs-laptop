#      fastfetch -c "$HOME/.config/fastfetch/config-compact.jsonc"
#    else
#      fastfetch
#    fi
#  fi
#fi
# ---------- Graphite Fastfetch Banner ----------
[[ -r "$HOME/.config/fastfetch/graphite-banner.sh" ]] && source "$HOME/.config/fastfetch/graphite-banner.sh"
