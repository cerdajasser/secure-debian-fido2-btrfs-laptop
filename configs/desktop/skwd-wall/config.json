{
  "compositor": "niri",
  "monitor": "",
  "paths": {
    "wallpaper": "/home/<USER>/Pictures/wallpapers/",
    "videoWallpaper": "/home/<USER>/Pictures/wallpapers/",
    "cache": "",
    "templates": "",
    "scripts": "",
    "steam": "/home/<USER>/.steam/debian-installation",
    "steamWorkshop": "/home/<USER>/.steam/debian-installation/steamapps/workshop/content/431960",
    "steamWeAssets": "/home/<USER>/.steam/debian-installation/steamapps/common/wallpaper_engine/assets"
  },
  "features": {
    "matugen": true,
    "ollama": true,
    "steam": true,
    "wallhaven": true,
    "videoAutoScale": true,
    "videoPreviewInstant": true
  },
  "colorSource": "magick",
  "ollama": {
    "url": "http://localhost:11434",
    "model": "moondream:latest",
    "consolidationModel": "moondream:latest",
    "prompt": ""
  },
  "steam": {
    "apiKey": "2A5EE911595D3363E08985A704214A3C",
    "username": "nica939"
  },
  "wallhaven": {
    "apiKey": ""
  },
  "matugen": {
    "schemeType": "scheme-fidelity",
    "mode": "light"
  },
  "integrations": [
    {
      "_comment": "Built-in: MD3 colors for the shell UI (always needed)",
      "name": "skwd-wall",
      "template": "quickshell-colors.json",
      "output": "colors.json"
    },
    {
      "name": "kitty",
      "template": "kitty.conf",
      "output": "~/.config/kitty/skwd-theme.conf",
      "reload": "pkill -USR1 kitty"
    },
    {
      "name": "ghostty",
      "template": "ghostty.conf",
      "output": "~/.config/ghostty/skwd-theme",
      "reload": "pkill -USR1 ghostty"
    },
    {
      "name": "niri",
      "template": "niri-colors.kdl",
      "output": "niri-primary-color",
      "reload": "~/.config/skwd-wall/scripts/reload-niri.sh"
    },
    {
      "name": "kde",
      "template": "kde-colors.colors",
      "output": "~/.local/share/color-schemes/SkwdMatugen.colors",
      "reload": "~/.config/skwd-wall/scripts/reload-kde.sh"
    },
    {
      "name": "vscode",
      "template": "vscode-theme.json",
      "output": "~/.vscode/extensions/matugen.matugen-theme-1.0.0/themes/matugen-color-theme.json"
    },
    {
      "name": "vesktop",
      "template": "vesktop.css",
      "output": "~/.config/vesktop/themes/kitty-match.css"
    },
    {
      "name": "spicetify",
      "template": "spicetify.ini",
      "output": "~/.config/spicetify/Themes/Matugen/color.ini",
      "reload": "~/.config/skwd-wall/scripts/reload-spicetify.sh"
    },
    {
      "name": "spicetify-css",
      "template": "spicetify.css",
      "output": "~/.config/spicetify/Themes/Matugen/user.css"
    },
    {
      "name": "yazi",
      "template": "yazi-theme.toml",
      "output": "~/.config/yazi/theme.toml"
    },
    {
      "name": "qt6ct",
      "template": "qt6ct-colors.conf",
      "output": "~/.config/qt6ct/colors/matugen.conf"
    },
    {
      "_comment": "Update output path with your Zen browser profile directory",
      "name": "zen",
      "template": "zen.css",
      "output": "~/.config/zen/PROFILE_DIR/chrome/userChrome.css"
    },
    {
      "name": "omp",
      "reload": "~/.config/skwd-wall/scripts/reload-omp.sh"
    }
  ],
  "components": {
    "wallpaperSelector": {
      "displayMode": "hex",
      "showColorDots": false,
      "sliceSpacing": -30,
      "hexScrollStep": 1,
      "customPresets": {
        "C1_hex": {
          "hexRadius": 140,
          "hexRows": 3,
          "hexCols": 7,
          "hexScrollStep": 1,
          "hexArc": true,
          "hexArcIntensity": 1.2
        },
        "C2_hex": {
          "hexRadius": 140,
          "hexRows": 3,
          "hexCols": 7,
          "hexScrollStep": 1,
          "hexArc": true,
          "hexArcIntensity": 1.2
        },
        "C3_hex": {
          "hexRadius": 140,
          "hexRows": 3,
          "hexCols": 7,
          "hexScrollStep": 1,
          "hexArc": true,
          "hexArcIntensity": 1.2
        },
        "C4_hex": {
          "hexRadius": 140,
          "hexRows": 3,
          "hexCols": 7,
          "hexScrollStep": 1,
          "hexArc": true,
          "hexArcIntensity": 1.2
        }
      },
      "hexArc": true,
      "hexArcIntensity": 1
    }
  },
  "wallpaperMute": true,
  "performance": {
    "imageOptimizePreset": "quality",
    "imageOptimizeResolution": "4k",
    "videoConvertPreset": "balanced",
    "videoConvertResolution": "2k",
    "autoOptimizeImages": true,
    "autoConvertVideos": false,
    "imageTrashDays": 7,
    "videoTrashDays": 7,
    "autoDeleteImageTrash": false,
    "autoDeleteVideoTrash": false
  },
  "postProcessOnRestore": false,
  "pickOnlyMode": false,
  "effects": {
    "autoRecolor": false,
    "autoTheme": "Nord"
  },
  "weRender": {
    "fullscreenPauseOnlyActive": true
  }
}
