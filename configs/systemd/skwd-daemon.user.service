[Unit]
Description=Skwd Daemon
Documentation=https://github.com/liixini/skwd-daemon
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/local/bin/skwd-daemon
Restart=on-failure
RestartSec=2
Environment=PATH=/home/<USER>/.cargo/bin:/usr/local/bin:/usr/bin:/bin
Environment=LD_LIBRARY_PATH=/usr/local/lib:/opt/linux-wallpaperengine/lib
Environment="RUST_LOG=info"

[Install]
WantedBy=graphical-session.target
